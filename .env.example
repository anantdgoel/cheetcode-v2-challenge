# Copy to .env.local and fill with your own values.

# Convex deployment used by Next.js app and API routes
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Admin key used by trusted Next.js server code for internal Convex functions
CONVEX_ADMIN_KEY=replace-with-convex-admin-key

# GitHub OAuth app credentials for sign-in
AUTH_GITHUB_ID=replace-with-github-oauth-client-id
AUTH_GITHUB_SECRET=replace-with-github-oauth-client-secret

# Auth.js session encryption secret
AUTH_SECRET=replace-with-random-32-byte-secret

# Comma-separated GitHub usernames allowed into /admin
# Also set this in Convex: npx convex env set ADMIN_GITHUB_LOGINS "..."
ADMIN_GITHUB_LOGINS=replace-with-your-github-login

# RSA private key used to sign Convex JWTs for authenticated users
CONVEX_AUTH_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ---------------------------------------------------------------------------
# The following are set in the Convex dashboard, not in .env.local.
# Run: npx convex env set VAR_NAME value
# ---------------------------------------------------------------------------
# CONVEX_AUTH_JWKS    — JWKS JSON containing the public key matching CONVEX_AUTH_PRIVATE_KEY
# OPENAI_API_KEY      — Required for admin summary generation
# JUDGE_MODEL         — Optional model override; defaults to gpt-5-mini
